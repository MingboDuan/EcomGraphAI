# MySQL
GMALL_MYSQL_HOST=localhost
GMALL_MYSQL_PORT=3306
GMALL_MYSQL_USER=root
GMALL_MYSQL_PASSWORD=your_mysql_password
GMALL_MYSQL_DATABASE=gmall

# Neo4j
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# LLM / DashScope compatible API
TONGYI_API_KEY=your_api_key
GRAPHRAG_LLM_PROVIDER=tongyi
GRAPHRAG_LLM_MODEL=qwen-turbo
GRAPHRAG_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# GraphRAG
GRAPHRAG_TOP_K=8
GRAPHRAG_RESULT_LIMIT=30


